{
  "name": "mono-geom",
  "version": "0.0.1",
  "description": "Mono GEOM",
  "private": true,
  "workspaces": [
    "express-geom",
    "react-geom"
  ],
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "prepare": "npx husky install || echo 'Husky no instalado, omitiendo prepare'",
    "build": "CI=false HTTPS=false PUBLIC_URL=/wp-content/reactpress/apps/react-geom/build react-scripts build",
    "data:trees:rebuild": "Rscript scripts/rebuild_tree_from_rdata.R",
    "data:trees:validate": "Rscript scripts/validate_tree_bubble_alignment.R",
    "data:sync:pdf-trees": "npm run data:trees:rebuild && npm run data:trees:validate && npm --prefix express-geom run seed && npm --prefix react-geom run build"
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@commitlint/cli": "^19.7.1",
    "@commitlint/config-conventional": "^19.7.1",
    "husky": "^9.1.4",
    "lint-staged": "^15.2.8"
  },
  "lint-staged": {
    "*.js": []
  }
}
